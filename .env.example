# =============================================================
# PUPA Innovation Expo — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

# ── Database (Neon PostgreSQL) ─────────────────────────────
# Pooled connection string (used by the app at runtime via Prisma).
# In Neon dashboard: Connection Details → Connection string → Pooled
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# Direct (non-pooled) connection string used by Prisma for migrations.
# In Neon dashboard: Connection Details → Connection string → Direct
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE"

# ── Clerk Authentication ────────────────────────────────────
# Obtain from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect URLs (optional overrides — defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/teams"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/teams"

# ── Next.js ────────────────────────────────────────────────
# Set to "production" on your hosting platform (Vercel sets this automatically).
NODE_ENV="development"
